{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lemz-jamz",
  "main": "worker.js",
  "compatibility_date": "2025-04-01",
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "r2_buckets": [
    {
      "binding": "MUSIC",
      "bucket_name": "lemz-jamz-music"
    }
  ]
}
